# Modelo Whisper via faster-whisper (baixa do Hugging Face — não é Ollama).
# tiny < base < small < medium < large-v3
MODEL_SIZE=small
MODEL_DEVICE=cpu
MODEL_COMPUTE_TYPE=int8

# Perfil de decodificação: fast | balanced | accurate
# - fast: beam 1, mais rápido, menos preciso
# - balanced: beam 3, bom custo/benefício (padrão)
# - accurate: beam 5, mais preciso, bem mais lento em CPU
STT_QUALITY_PROFILE=fast

# Sobrescrevem o perfil (deixe vazio para usar só o perfil):
# BEAM_SIZE=
# BEST_OF=
# PATIENCE=
# CONDITION_ON_PREVIOUS_TEXT=true
# COMPRESSION_RATIO_THRESHOLD=2.3
# LOG_PROB_THRESHOLD=-1.0
# NO_SPEECH_THRESHOLD=0.5

# Ajuste fino do VAD (JSON). Ex.: silêncios curtos entre palavras
# VAD_PARAMETERS_JSON={"min_silence_duration_ms":400,"threshold":0.5}

# Nomes/termos de negócio (vírgula), favorecidos na transcrição
# STT_HOTWORDS=Acme, sprint, backlog, standup
PRELOAD_MODEL=true

DEFAULT_LANGUAGE=pt
DEFAULT_VAD_FILTER=true
API_TOKEN=troque-este-token

# Hugging Face (totalmente opcional — o modelo baixa sem token; o token só reduz avisos e melhora rate limit)
# HF_TOKEN=hf_...

# Cloudflare Tunnel (perfil "tunnel": cloudflared + STT)
# Token do painel Zero Trust → Tunnels → o túnel → Install → token.
# Nunca commite este valor; use só em .env na máquina.
# No painel, a origem privada deve apontar para o serviço Docker, ex.: http://stt:8000
# (não use http://localhost:8000 no painel se o cloudflared estiver no container).
# CLOUDFLARE_TUNNEL_TOKEN=
