# Copie este arquivo para .env e preencha os valores.
# GOOGLE_CLOUD_SPEECH_API_KEY= token OAuth 2 (não a API Key do Console). Deixe vazio para usar reconhecimento do sistema (com beep).
# Para token: gcloud auth application-default login && gcloud auth application-default print-access-token

GOOGLE_CLOUD_SPEECH_API_KEY=
